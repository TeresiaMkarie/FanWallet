# ── Fan Wallet execution service ─────────────────────────────────────────────
# Copy to .env and adjust. Never commit your real .env.

PORT=8787

# EVM testnet RPC (default: public Sepolia). Any EVM RPC or EIP-1193 endpoint.
RPC_URL=https://sepolia.drpc.org
CHAIN=Sepolia
EXPLORER_URL=https://sepolia.etherscan.io

# The ERC-20 the app treats as "USD₮". Since public testnet USDt faucets aren't
# reliably available, this is our own TestUSDT (contracts/TestUSDT.sol).
# Run `npm run deploy:token` to deploy it — it fills in USDT_TOKEN_ADDRESS and
# TREASURY_PRIVATE_KEY below automatically. Leave blank until you've done that.
USDT_TOKEN_ADDRESS=
USDT_DECIMALS=6
USDT_SYMBOL=USD₮

# At-rest encryption key for stored seed phrases (demo custody — see README).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_SECRET=change-me-to-a-long-random-string

# Programmable spending policy (foundation of the smart-account feature).
POLICY_PER_TX_LIMIT=500
POLICY_DAILY_LIMIT=1000

# ── Treasury / test-token faucet ─────────────────────────────────────────────
# Owns TestUSDT (the minter) and auto-funds every wallet the app creates with
# test USD₮ + a little native gas, so nobody needs a testnet USDt faucet.
# `npm run deploy:token` generates this key for you on first run, then tells
# you to fund it with testnet ETH and re-run to deploy.
# Keep FAUCET_NATIVE_AMOUNT small — it's paid out of the treasury's own testnet
# ETH on every wallet creation, and Sepolia gas is cheap (0.003 covers dozens
# of transfers per wallet). A typical faucet drip (0.05-0.5 ETH) into the
# treasury then funds many wallets, not just one or two.
TREASURY_PRIVATE_KEY=
FAUCET_USDT_AMOUNT=1000
FAUCET_NATIVE_AMOUNT=0.003
