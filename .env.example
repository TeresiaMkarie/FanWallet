# ── Fan Wallet execution service ─────────────────────────────────────────────
# Copy to .env and adjust. Never commit your real .env.

PORT=8787

# EVM testnet RPC (default: public Sepolia). Any EVM RPC or EIP-1193 endpoint.
RPC_URL=https://sepolia.drpc.org
CHAIN=Sepolia
EXPLORER_URL=https://sepolia.etherscan.io

# The ERC-20 the app treats as "USD₮". Default is Sepolia test USDC (6 decimals),
# which has public faucets. Swap for a real testnet USD₮/XAU₮ token when available.
USDT_TOKEN_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
USDT_DECIMALS=6
USDT_SYMBOL=USD₮

# At-rest encryption key for stored seed phrases (demo custody — see README).
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_SECRET=change-me-to-a-long-random-string

# Programmable spending policy (foundation of the smart-account feature).
POLICY_PER_TX_LIMIT=500
POLICY_DAILY_LIMIT=1000
